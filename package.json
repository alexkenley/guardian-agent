{
  "name": "guardianagent",
  "version": "1.0.0",
  "description": "Security-first AI agent orchestration with four-layer defense system",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "guardianagent": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:llmmap": "node scripts/test-llmmap-security.mjs",
    "test:verbose": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "check": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "dev:unix": "bash scripts/start-dev-unix.sh",
    "dev:sh": "bash scripts/start-dev-unix.sh",
    "portable:windows": "powershell -ExecutionPolicy Bypass -File scripts/make-windows-portable.ps1",
    "helper:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-helper.ps1",
    "package:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-package.ps1",
    "installer:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-installer.ps1",
    "release:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-release.ps1",
    "start": "node dist/index.js",
    "vendor:monaco": "node scripts/vendor-monaco.mjs",
    "postinstall": "node scripts/vendor-monaco.mjs",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "ollama",
    "guardian",
    "security",
    "orchestration",
    "personal-assistant"
  ],
  "author": "Alexander Kenley",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexkenley/guardian-agent.git"
  },
  "homepage": "https://github.com/alexkenley/guardian-agent",
  "bugs": {
    "url": "https://github.com/alexkenley/guardian-agent/issues"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "monaco-editor": "^0.55.1",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-cloudwatch": "^3.1006.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1006.0",
    "@aws-sdk/client-cost-explorer": "^3.1006.0",
    "@aws-sdk/client-ec2": "^3.1006.0",
    "@aws-sdk/client-iam": "^3.1006.0",
    "@aws-sdk/client-lambda": "^3.1006.0",
    "@aws-sdk/client-rds": "^3.1006.0",
    "@aws-sdk/client-route-53": "^3.1006.0",
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/client-sts": "^3.1006.0",
    "@daytona/sdk": "^0.164.0",
    "@playwright/mcp": "^0.0.68",
    "@vercel/sandbox": "^1.9.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^8.18.0",
    "croner": "^10.0.1",
    "grammy": "^1.40.0",
    "js-yaml": "^4.1.1",
    "node-pty": "^1.1.0",
    "ollama": "0.6.3",
    "openai": "^6.24.0",
    "pino": "^10.3.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "pdf-parse": "^2.4.5"
  },
  "overrides": {
    "@appium/logger": {
      "lodash": "4.17.23"
    }
  }
}
